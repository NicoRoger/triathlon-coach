# ============================================================================
# Local development. In CI usare GitHub Secrets, in Workers usare wrangler secret.
# ============================================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Garmin (base64 di ~/.garminconnect/* dopo primo login)
GARMIN_SESSION_JSON=

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DR
DR_ENCRYPTION_KEY=  # genera: openssl rand -base64 32

# MCP
MCP_BEARER_TOKEN=  # genera: openssl rand -base64 48

# Healthchecks (opzionale)
HEALTHCHECKS_PING_URL_GARMIN_SYNC=
HEALTHCHECKS_PING_URL_STRAVA_SYNC=
HEALTHCHECKS_PING_URL_BRIEFING_MORNING=
HEALTHCHECKS_PING_URL_WATCHDOG=

# Misc
INGEST_DAYS_BACK=7
